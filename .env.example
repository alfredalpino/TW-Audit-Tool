# ── Supabase (same project as torpedoweb.org main site) ──
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle — Dashboard → Database → Connection string → URI
# Vercel (production): Transaction pooler (6543) with IPv4 pooler host, e.g.:
#   postgresql://postgres.<ref>:PASS@aws-1-<region>.pooler.supabase.com:6543/postgres
#   (Supabase Dashboard → Connect → ORMs → Transaction pooler URI)
# Local dev without Supabase: Docker Compose below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tw_audit

# Rate limiting (in-memory; per IP / hour; domain limit is 5/hour)
AUDIT_RATE_LIMIT_PER_HOUR=10
AUDIT_API_RATE_LIMIT_PER_HOUR=100

# Optional API keys for POST /api/audits (comma-separated; send X-API-Key header)
# AUDIT_API_KEYS=your-secret-key,partner-key-2

# Audit processing — Vercel processes on GET poll (fetch/Cheerio). No separate worker required.
# Local dev without optional worker: set AUDIT_USE_FETCH=true so polls process inline.
# AUDIT_USE_FETCH=true
AUDIT_USE_MOCK=false

# Optional background worker only (Render/local Playwright pipeline — NOT needed for production)
# See worker/README.md and render.yaml
# WORKER_CONCURRENCY=2
# WORKER_POLL_INTERVAL_MS=2000

# Screenshot storage (local path; Supabase bucket audit-screenshots on Vercel)
SCREENSHOT_STORAGE_PATH=./storage/screenshots

# PDF reports (local path; generated on unlock)
REPORT_STORAGE_PATH=./storage/reports

# Resend — audit report email with PDF attachment (optional locally)
# Setup: https://resend.com → verify torpedoweb.org → API key (free: 100 emails/day)
# Use the SAME RESEND_API_KEY as main site + offer page. Do NOT wrap values in quotes.
RESEND_API_KEY=
# From address must use your verified domain (subdomain optional)
RESEND_FROM_EMAIL=Torpedo Web <reports@audit.torpedoweb.org>
# Fallback if you only set BOOKING_FROM_EMAIL on other apps (same Resend account)
# BOOKING_FROM_EMAIL=Torpedo Web <hello@invite.torpedoweb.org>

# Strategy call CTA in UI + report email (matches main site book.torpedoweb.org)
NEXT_PUBLIC_BOOKING_URL=https://book.torpedoweb.org

# NextAuth (org dashboard auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 5 — admin-lite (protects /admin and /api/admin/*)
ADMIN_SECRET=generate-with-openssl-rand-base64-32
# Optional default org for public audits (slug from organizations table)
# DEFAULT_ORGANIZATION_SLUG=torpedo
