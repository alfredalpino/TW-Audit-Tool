# ── OPTIONAL Render worker environment ──
# Production uses Vercel-only processing (no worker). Use this only for Playwright/Lighthouse.
# Copy these into Render → tw-audit-worker → Environment

# REQUIRED — Supabase DIRECT Postgres (port 5432)
# Dashboard → Database → Connection string → URI (not pooler)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Worker tuning
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=2000

# Pipeline (keep false on worker — uses Playwright + Lighthouse + axe)
AUDIT_USE_MOCK=false
AUDIT_USE_FETCH=false

# Optional — screenshot storage (use Supabase bucket audit-screenshots in production)
SCREENSHOT_STORAGE_PATH=/tmp/tw-audit-screenshots

# Optional — same Supabase project as Vercel (for screenshot uploads)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional — PDF/email (only if worker should send reports)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Torpedo Web <reports@audit.torpedoweb.org>
